generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BroadField {
  id                      String  @id
  nameEn                  String
  nameZh                  String
  recentMedianEarningsEn  String
  recentMedianEarningsVal Int
  primeMedianEarningsEn   String
  primeMedianEarningsVal  Int
  gradPremiumPercent      Float
  gradDegreePercent       Float
  majors                  Major[]
}

model DetailedField {
  id                            String  @id
  nameEn                        String
  nameZh                        String
  broadFieldId                  String
  primeMedianEarningsVal        Int
  unemploymentRecentPercent     Float
  unemploymentPrimePercent      Float
  degreeProductionChangePercent Float
  majors                        Major[]
}

model Major {
  id                       String                       @id
  nameEn                   String
  nameZh                   String
  nameZht                  String?
  broadFieldId             String
  detailedFieldId          String
  specialTag               String?
  earningsValue            Int?
  mathDemand               String?
  physicsDemand            String?
  chemistryDemand          String?
  biologyDemand            String?
  humanitiesDemand         String?
  institutionProgramFields InstitutionProgramField[]
  broadField               BroadField                   @relation(fields: [broadFieldId], references: [id])
  detailedField            DetailedField                @relation(fields: [detailedFieldId], references: [id])
  cipMappings              MajorCipMapping[]
  majorRankings            MajorRanking[]
  universityAssociations   UniversityMajorAssociation[]
}

model University {
  id                       String                         @id @default(uuid())
  nameEn                   String                         @unique
  nameZh                   String?
  nameZht                  String?
  countryEn                String
  countryZh                String?
  logoUrl                  String?
  rankingQs                Int?
  rankingUsNews            Int?
  latitude                 Float?
  longitude                Float?
  wikidataId               String?                        @unique
  scorecardUnitId          String?                        @unique
  averageCost              Int?
  gradRate                 Float?
  medianSalary             Int?
  comparisonOptions        ComparisonOption[]
  institutionCandidates    InstitutionCandidate[]
  institutionMetrics       InstitutionMetric[]
  institutionProgramFields InstitutionProgramField[]
  publishDecisions         InstitutionPublishDecision[]
  majorRankings            MajorRanking[]
  schools                  School[]
  externalIdentifiers      UniversityExternalIdentifier[]
  customMajors             UniversityMajorAssociation[]
  rankingLineages          UniversityRankingLineage[]
}

model School {
  id           String                       @id @default(uuid())
  nameEn       String
  nameZh       String?
  universityId String
  university   University                   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  customMajors UniversityMajorAssociation[]
}

model UniversityMajorAssociation {
  id              String     @id @default(uuid())
  universityId    String
  schoolId        String?
  customName      String
  customCode      String?
  standardMajorId String?
  mappingScore    Float      @default(0.0)
  isValidated     Boolean    @default(false)
  degreeLevel     String     @default("BACHELOR")
  sourceUrl       String?
  createdAt       DateTime   @default(now())
  school          School?    @relation(fields: [schoolId], references: [id])
  standardMajor   Major?     @relation(fields: [standardMajorId], references: [id])
  university      University @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

model UniversityRankingLineage {
  id           String     @id @default(uuid())
  universityId String
  rankInteger  Int
  year         Int
  source       String
  isGlobal     Boolean    @default(false)
  tieCount     Int        @default(0)
  sourceUrl    String?
  isVerified   Boolean    @default(false)
  verifiedBy   String?
  verifiedAt   DateTime?
  createdAt    DateTime   @default(now())
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, year, source, isGlobal])
}

model User {
  id                    String                @id @default(uuid())
  email                 String                @unique
  name                  String?
  passwordHash          String                @default("")
  emailVerified         Boolean               @default(false)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  disabled              Boolean               @default(false)
  role                  String                @default("FREE")
  userType              String                @default("STUDENT")
  schoolName            String?
  gradYear              Int?
  counselorSpecialty    String?
  teacherSubject        String?
  customNote            String?
  subscriptionStatus    String                @default("none")
  subscriptionEndsAt    DateTime?
  counselorInviteCode   String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  counselorNotes        CounselorNote[]
  reportGenerations     ReportGeneration[]
  savedItems            SavedItem[]
  counselorWorkspaces   StudentWorkspace[]    @relation("CounselorWorkspace")
  studentWorkspaces     StudentWorkspace[]    @relation("StudentWorkspace")
  subscriptionHistories SubscriptionHistory[]
}

model SavedItem {
  id        String   @id @default(uuid())
  userId    String
  itemType  String
  itemId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
}

model MajorRanking {
  id              String     @id @default(uuid())
  universityId    String
  standardMajorId String
  rankInteger     Int
  year            Int
  source          String
  verificationId  String
  sourceUrl       String?
  createdAt       DateTime   @default(now())
  standardMajor   Major      @relation(fields: [standardMajorId], references: [id])
  university      University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([universityId, standardMajorId, year, source])
}

model UniversityExternalIdentifier {
  id              String     @id @default(uuid())
  universityId    String
  identifierType  String
  identifierValue String
  sourceSystem    String
  verificationId  String?
  createdAt       DateTime   @default(now())
  university      University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([identifierType, identifierValue])
  @@index([universityId, identifierType])
}

model MetricDefinition {
  metricKey          String              @id
  labelEn            String
  labelZh            String?
  descriptionEn      String?
  descriptionZh      String?
  valueType          String
  unit               String?
  displayFormat      String
  higherIsBetter     Boolean?
  sourceSystem       String
  sourceTable        String?
  sourceVariable     String?
  requiredDimensions Json?
  missingValuePolicy String
  isPublicVisible    Boolean             @default(false)
  version            String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  metrics            InstitutionMetric[]
}

model InstitutionMetric {
  id               String           @id @default(uuid())
  metricKey        String
  universityId     String?
  unitId           String
  valueNumeric     Float?
  valueText        String?
  valueStatus      String
  missingReason    String?
  rawValue         String?
  denominator      Float?
  cohort           String?
  academicYear     String
  sourceSystem     String
  sourceTable      String
  sourceVariable   String
  releaseKey       String
  verificationId   String           @unique
  computedAt       DateTime         @default(now())
  metricDefinition MetricDefinition @relation(fields: [metricKey], references: [metricKey])
  university       University?      @relation(fields: [universityId], references: [id])

  @@index([unitId, metricKey])
  @@index([universityId, metricKey])
  @@index([releaseKey, sourceTable, sourceVariable])
}

model CipCode {
  code                     String                    @id
  title                    String
  version                  String                    @default("CIP2020")
  level                    String
  parentCode               String?
  createdAt                DateTime                  @default(now())
  institutionProgramFields InstitutionProgramField[]
  mappings                 MajorCipMapping[]
}

model MajorCipMapping {
  id             String    @id @default(uuid())
  majorId        String
  cipCode        String
  mappingScore   Float     @default(0)
  mappingMethod  String
  status         String    @default("REVIEW_REQUIRED")
  sourceSystem   String    @default("IPEDS")
  verificationId String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  cip            CipCode   @relation(fields: [cipCode], references: [code], onDelete: Cascade)
  major          Major     @relation(fields: [majorId], references: [id], onDelete: Cascade)

  @@unique([majorId, cipCode])
  @@index([cipCode, status])
}

model InstitutionCandidate {
  id               String                       @id @default(uuid())
  unitId           String                       @unique
  universityId     String?
  nameEn           String
  state            String?
  control          String?
  sector           String?
  level            String?
  eligibilityScore Float?
  recommendation   String?
  reasons          Json?
  warnings         Json?
  blockingReasons  Json?
  policyVersion    String?
  releaseKey       String
  computedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  university       University?                  @relation(fields: [universityId], references: [id])
  publishDecisions InstitutionPublishDecision[]

  @@index([recommendation])
  @@index([universityId])
}

model InstitutionProgramField {
  id               String      @id @default(uuid())
  universityId     String?
  unitId           String
  cipCode          String
  displayTitle     String
  standardMajorId  String?
  degreeLevel      String
  sourceType       String
  programOffered   Int?
  completionsTotal Int?
  activityStatus   String
  valueStatus      String
  sourceSystem     String
  sourceTable      String
  sourceVariable   String
  releaseKey       String
  verificationId   String      @unique
  computedAt       DateTime    @default(now())
  cip              CipCode     @relation(fields: [cipCode], references: [code])
  standardMajor    Major?      @relation(fields: [standardMajorId], references: [id])
  university       University? @relation(fields: [universityId], references: [id])

  @@unique([unitId, cipCode, degreeLevel, releaseKey, sourceType])
  @@index([unitId, degreeLevel])
  @@index([universityId, degreeLevel])
  @@index([cipCode])
  @@index([standardMajorId])
}

model InstitutionPublishDecision {
  id           String               @id @default(uuid())
  candidateId  String
  universityId String?
  status       String
  decidedBy    String?
  decidedAt    DateTime?
  reason       String?
  createdAt    DateTime             @default(now())
  candidate    InstitutionCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  university   University?          @relation(fields: [universityId], references: [id])

  @@index([candidateId, status])
  @@index([universityId, status])
}

model SubscriptionHistory {
  id        String   @id @default(uuid())
  userId    String
  changedBy String
  field     String
  oldValue  String?
  newValue  String?
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StudentWorkspace {
  id                 String              @id @default(uuid())
  counselorId        String
  studentId          String?
  inviteEmail        String
  inviteToken        String              @unique
  inviteAccepted     Boolean             @default(false)
  createdAt          DateTime            @default(now())
  comparisonSessions ComparisonSession[]
  counselorNotes     CounselorNote[]
  decisionProfile    DecisionProfile?
  counselor          User                @relation("CounselorWorkspace", fields: [counselorId], references: [id], onDelete: Cascade)
  student            User?               @relation("StudentWorkspace", fields: [studentId], references: [id])

  @@index([counselorId])
  @@index([inviteToken])
  @@index([studentId])
}

model DecisionProfile {
  id              String           @id @default(uuid())
  workspaceId     String           @unique
  gpa             Float?
  satScore        Int?
  actScore        Int?
  annualBudgetMin Int?
  annualBudgetMax Int?
  interestAreas   Json?
  updatedAt       DateTime         @updatedAt
  workspace       StudentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  weights         ProfileWeight?
}

model ProfileWeight {
  id             String          @id @default(uuid())
  profileId      String          @unique
  salaryWeight   Float           @default(0.25)
  prestigeWeight Float           @default(0.25)
  costWeight     Float           @default(0.25)
  fitWeight      Float           @default(0.25)
  profile        DecisionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ComparisonSession {
  id          String             @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime           @default(now())
  options     ComparisonOption[]
  workspace   StudentWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reports     ReportGeneration[]

  @@index([workspaceId])
}

model ComparisonOption {
  id           String            @id @default(uuid())
  sessionId    String
  universityId String
  majorId      String?
  sortOrder    Int               @default(0)
  session      ComparisonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  university   University        @relation(fields: [universityId], references: [id])

  @@index([sessionId])
  @@index([universityId])
}

model CounselorNote {
  id          String           @id @default(uuid())
  workspaceId String
  counselorId String
  noteType    String           @default("other")
  content     String
  isShared    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  counselor   User             @relation(fields: [counselorId], references: [id], onDelete: Cascade)
  workspace   StudentWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([counselorId])
}

model ReportGeneration {
  id          String            @id @default(uuid())
  sessionId   String
  generatedBy String
  pdfUrl      String?
  generatedAt DateTime          @default(now())
  generator   User              @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
  session     ComparisonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([generatedBy])
}
