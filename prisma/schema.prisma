datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model BroadField {
  id                      String   @id
  nameEn                  String
  nameZh                  String
  recentMedianEarningsEn  String
  recentMedianEarningsVal Int
  primeMedianEarningsEn   String
  primeMedianEarningsVal  Int
  gradPremiumPercent      Float
  gradDegreePercent       Float
  majors                  Major[]
}

model DetailedField {
  id                            String   @id
  nameEn                        String
  nameZh                        String
  broadFieldId                  String
  primeMedianEarningsVal        Int
  unemploymentRecentPercent     Float
  unemploymentPrimePercent      Float
  degreeProductionChangePercent Float
  majors                        Major[]
}

model Major {
  id               String                       @id
  nameEn           String
  nameZh           String
  nameZht          String?
  broadFieldId     String
  broadField       BroadField                   @relation(fields: [broadFieldId], references: [id])
  detailedFieldId  String
  detailedField    DetailedField                @relation(fields: [detailedFieldId], references: [id])
  specialTag       String?                      // 'highest', 'lowest', or null
  earningsValue    Int?                         // Peak earnings if individual spotlighted major
  mathDemand       String?                      // 'H', 'M', 'L'
  physicsDemand    String?                      // 'H', 'M', 'L'
  chemistryDemand  String?                      // 'H', 'M', 'L'
  biologyDemand    String?                      // 'H', 'M', 'L'
  humanitiesDemand String?                      // 'H', 'M', 'L'
  
  // Linkages to custom university majors
  universityAssociations UniversityMajorAssociation[]
  majorRankings          MajorRanking[]
}

model University {
  id              String                       @id @default(uuid())
  nameEn          String                       @unique
  nameZh          String?
  nameZht         String?
  countryEn       String
  countryZh       String?
  logoUrl         String?
  rankingQs       Int?
  rankingUsNews   Int?
  latitude        Float?
  longitude       Float?
  wikidataId      String?                      @unique
  
  // U.S. College Scorecard metrics
  scorecardUnitId String?                      @unique // IPEDS UNITID
  averageCost     Int?
  gradRate        Float?
  medianSalary    Int?
  
  schools         School[]
  customMajors    UniversityMajorAssociation[]
  rankingLineages UniversityRankingLineage[]
  majorRankings   MajorRanking[]
}

model School {
  id              String                       @id @default(uuid())
  nameEn          String
  nameZh          String?
  universityId    String
  university      University                   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  customMajors    UniversityMajorAssociation[]
}

model UniversityMajorAssociation {
  id              String      @id @default(uuid())
  universityId    String
  university      University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  schoolId        String?
  school          School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  customName      String      // e.g. "Electrical & Computer Engineering with Honors"
  customCode      String?     // Specific school program code
  
  // Standard major mapping
  standardMajorId String
  standardMajor   Major       @relation(fields: [standardMajorId], references: [id])
  
  mappingScore    Float       @default(0.0)  // Semantic / Lexical similarity score
  isValidated     Boolean     @default(false) // Manual audit flag
  degreeLevel     String      @default("BACHELOR") // 'BACHELOR' | 'MASTER' | 'DOCTORATE'
  createdAt       DateTime    @default(now())
}

model UniversityRankingLineage {
  id            String   @id @default(uuid())
  universityId  String
  university    University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  rankInteger   Int
  year          Int
  source        String   // 'QS', 'US_NEWS', 'DOE_SCORECARD'
  isGlobal      Boolean  @default(false)
  tieCount      Int      @default(0)
  sourceUrl     String?  // Reference verification URL
  isVerified    Boolean  @default(false)
  verifiedBy    String?  // Admin username or automation engine identifier
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())

  @@unique([universityId, year, source, isGlobal])
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  name               String?
  role               String      @default("FREE") // 'GUEST' | 'FREE' | 'PRO' | 'ADMIN'
  userType           String      @default("STUDENT") // 'STUDENT' | 'TEACHER' | 'COUNSELOR' | 'PARENT' | 'OTHER'
  schoolName         String?
  gradYear           Int?
  counselorSpecialty String?
  teacherSubject     String?
  customNote         String?
  subscriptionStatus String      @default("none") // 'active' | 'trialing' | 'canceled' | 'none'
  subscriptionEndsAt DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  savedItems         SavedItem[]
}

model SavedItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  String   // 'MAJOR' | 'UNIVERSITY'
  itemId    String   // references standard Major.id or University.id
  createdAt DateTime @default(now())

  @@unique([userId, itemType, itemId])
}

model MajorRanking {
  id              String      @id @default(uuid())
  universityId    String
  university      University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  standardMajorId String
  standardMajor   Major       @relation(fields: [standardMajorId], references: [id])
  
  rankInteger     Int
  year            Int
  source          String      // e.g. 'US_NEWS_CS', 'QS_CS', 'THE_CS', etc.
  verificationId  String      // e.g. 'USN-2026-CS-001'
  sourceUrl       String?
  createdAt       DateTime    @default(now())

  @@unique([universityId, standardMajorId, year, source])
}
